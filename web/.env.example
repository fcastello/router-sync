# Dev proxy target (vite.config.ts). Copy to .env.development.local to customize.
# Host where router-sync API listens (default :18080)
VITE_API_PROXY=http://127.0.0.1:18080

# Direct API URL (skip proxy; use Settings page or this for production builds)
# VITE_API_BASE_URL=http://192.168.2.252:18080
